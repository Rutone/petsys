# ── Орчны хувьсагчдын жишээ ──
# Энэ файлыг хуулж `.env` болгоод утгуудыг бөглөнө үү. `.env` нь GitHub-д орохгүй (нууц).

# Auth.js нууц түлхүүр (ЗААВАЛ). Дараах командаар санамсаргүй утга үүсгэнэ:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Сайтын үндсэн URL (нууц үг сэргээх холбоос, мэдэгдэлд ашиглана)
APP_URL="http://localhost:3000"

# Өгөгдлийн сан.
#   Dev (SQLite):       file:./dev.db
#   Production (Postgres): postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="file:./dev.db"

# ── SMTP (имэйл бодитоор илгээх; ЗААВАЛ БИШ) ──
# Тохируулаагүй бол dev горимд имэйл серверийн консолд хэвлэгдэнэ.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_SECURE="false"

# ── Орчны хувьсагчдын жишээ ──
# Энэ файлыг хуулж `.env` болгоод утгуудыг бөглөнө үү. `.env` нь GitHub-д орохгүй (нууц).

# Auth.js нууц түлхүүр (ЗААВАЛ). Дараах командаар санамсаргүй утга үүсгэнэ:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Сайтын үндсэн URL (нууц үг сэргээх холбоос, мэдэгдэлд ашиглана)
#   Local: http://localhost:3000   |   Production: https://<project>.vercel.app
APP_URL="http://localhost:3000"

# ── Өгөгдлийн сан (libSQL / Turso) ──
#   Local dev:   file:./dev.db   (локал SQLite файл, TURSO_AUTH_TOKEN хэрэггүй)
#   Production:  libsql://<database>-<org>.turso.io   (+ доорх токен)
DATABASE_URL="file:./dev.db"
# Turso ашиглах үед л шаардлагатай (local file үед хоосон үлдээнэ)
TURSO_AUTH_TOKEN=""

# ── Файл хавсралт (Vercel Blob) ──
# Vercel дээр Blob store холбоход автоматаар тохирно. Local dev-д хоосон бол
# public/uploads локал диск рүү хадгална.
BLOB_READ_WRITE_TOKEN=""

# ── SMTP (имэйл бодитоор илгээх; ЗААВАЛ БИШ) ──
# Тохируулаагүй бол dev горимд имэйл серверийн консолд хэвлэгдэнэ.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_SECURE="false"
